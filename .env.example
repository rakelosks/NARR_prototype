# NARR — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# LLM Provider: "ollama" (default, local) or "openai" (cloud)
# ---------------------------------------------------------------------------
LLM_PROVIDER=ollama

# OpenAI (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_INTENT_MODEL=gpt-4o-mini
OPENAI_GENERATION_MODEL=gpt-4o

# Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_INTENT_MODEL=qwen3:4b
OLLAMA_GENERATION_MODEL=qwen3:4b
OLLAMA_INTENT_THINK=false
OLLAMA_GENERATION_THINK=true
OLLAMA_TIMEOUT=180

# ---------------------------------------------------------------------------
# CKAN Open Data Portal
# ---------------------------------------------------------------------------
CKAN_PORTAL_URL=https://gagnagatt.reykjavik.is/en/api/3
CKAN_PORTAL_LANGUAGE=is

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
METADATA_DB_PATH=metadata.sqlite
CACHE_DIR=data/cache/snapshots
CACHE_TTL_HOURS=24

# ---------------------------------------------------------------------------
# API Security (leave empty to disable for local development)
# ---------------------------------------------------------------------------
NARR_API_KEY=
RATE_LIMIT_RPM=60
TRUST_PROXY_HEADERS=false

# ---------------------------------------------------------------------------
# Debug
# ---------------------------------------------------------------------------
DEBUG=false
